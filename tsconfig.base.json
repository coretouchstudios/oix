{
  "compilerOptions": {

    "target": "ES2022",

    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "jsx": "preserve",

    "strict": false,

    "skipLibCheck": true,

    "esModuleInterop": true,

    "resolveJsonModule": true,

    "forceConsistentCasingInFileNames": true
  }
}