{
  "$schema": "https://turbo.build/schema.json",

  "globalDependencies": [
    "package.json",
    "tsconfig.json"
  ],

  "tasks": {

    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        "dist/**"
      ]
    },

    "dev": {
      "cache": false
    },

    "lint": {},

    "clean": {
      "cache": false
    }
  }
}