{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "jsx": "preserve",

    "strict": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },

    "skipLibCheck": true,
    "resolveJsonModule": true
  },

  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx"
  ],

  "exclude": [
    "node_modules"
  ]
}